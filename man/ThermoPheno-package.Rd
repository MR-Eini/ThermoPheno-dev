\name{ThermoPheno-package}
\alias{ThermoPheno-package}
\docType{package}
\title{ThermoPheno: Thermal-Time-Based Crop Phenology Model}
\description{
ThermoPheno provides functions and a Shiny application for simulating crop phenology using daily thermal time.
}
\details{
The package supports simple, capped, and triangular thermal-time formulations; summer and winter crops; configurable planting and harvest windows; and validation-oriented workflows.
}
\references{
Package repository: \url{https://github.com/MR-Eini/ThermoPheno-dev}
}
\author{Mohammad Reza Eini}
